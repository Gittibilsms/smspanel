@{
    ViewData["Title"] = "Pricing";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<div class="page-header d-flex justify-content-between">
    <h3 class="page-title"># @SharedResource.Pricing</h3>
</div>

@if (TempData["SuccessMessage"] != null)
{
    <div class="alert alert-success">
        @TempData["SuccessMessage"]
    </div>
}
@if (TempData["ErrorMessage"] != null)
{
    <div class="alert alert-danger">
        @TempData["ErrorMessage"]
    </div>
}

<div class="row">
    <!-- Pricing Form -->
    <div class="col-lg-6">
        <div class="card">
            <div class="card-header">
                <h5 class="card-title mb-0">@SharedResource.Pricing</h5>
            </div>
            <div class="card-body">
                <form method="post" action="/Pricing/Update" autocomplete="off" >
                    @Html.AntiForgeryToken()
                    <div class="mb-3">
                        <label class="form-label">@SharedResource.Currency</label>
                        <select name="currency" class="form-select" required>
                            <option value="">@SharedResource.Currency</option>
                            <option value="TRY" selected>TRY</option>                            
                        </select>
                    </div>

                    <div class="mb-3">
                        <label class="form-label">@SharedResource.Low__1_500_000_SMS_unit_price_</label>
                        <input type="number" id="lowInput" name="low" class="form-control" step="0.0001" min="0" required
                               value="@(ViewBag.LatestPricing != null ? ViewBag.LatestPricing.Low.ToString("0.####", System.Globalization.CultureInfo.InvariantCulture) : "")">
                    </div>

                    <div class="mb-3">
                        <label class="form-label">@SharedResource.Medium__500_000_1_000_000_SMS_unit_price_</label>
                        <input type="number" id="middleInput"  name="middle" class="form-control" step="0.0001" min="0" required
                               value="@(ViewBag.LatestPricing != null ? ViewBag.LatestPricing.Middle.ToString("0.####", System.Globalization.CultureInfo.InvariantCulture) : "")">
                    </div>

                    <div class="mb-3">
                        <label class="form-label">@SharedResource.High__1_000_000__SMS_unit_price_</label>
                        <input type="number" id="highInput" name="high" class="form-control" step="0.0001" min="0" required
                               value="@(ViewBag.LatestPricing != null ? ViewBag.LatestPricing.High.ToString("0.####", System.Globalization.CultureInfo.InvariantCulture) : "")">
                    </div>
                    <div id="pricingClientError" class="text-danger small mb-2"></div>
                    <div class="d-flex justify-content-between">
                        <button type="submit" name="action" value="update" class="btn btn-success">@SharedResource.Update</button>
                        <button type="submit" name="action" value="remove" id="removeBtn" style="display:none;" class="btn btn-danger">@SharedResource.Remove_Special_Pricing</button>
                      
                    </div>
                </form>
            </div>
        </div>
    </div>

    <!-- Pricing History Table -->
    <div class="col-lg-6">
        <div class="card">
            <div class="card-header">
                <h5 class="card-title mb-0">@SharedResource.Pricing_History</h5>
            </div>
            <div class="card-body">
                <div class="table-responsive">
                <table class="table table-bordered align-middle">
                    <thead class="table-light">
                        <tr>
                            <th>@SharedResource.Currency</th>
                            <th>@SharedResource.Low</th>
                            <th>@SharedResource.Medium</th>
                            <th>@SharedResource.High</th>
                            <th>@SharedResource.Creation_Date</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var pricing in ViewBag.PricingHistory as List<GittBilSmsCore.Models.Pricing>)
                        {
                            <tr>
                                <td>@pricing.Currency</td>
                                <td>@pricing.Low</td>
                                <td>@pricing.Middle</td>
                                <td>@pricing.High</td>
                                <td>@pricing.CreatedAt.ToLocalTime().ToString("dd/MM/yyyy HH:mm")</td>
                            </tr>
                        }
                    </tbody>
                </table>
                </div>
            </div>
        </div>
    </div>
</div>
@section Scripts {
    <script>
        (function () {
            const form = document.getElementById('pricingForm');
            const errBox = document.getElementById('pricingClientError');
            const removeBtn = document.getElementById('removeBtn');

            removeBtn.addEventListener('click', function (e) {
                if (!confirm('Remove the current active pricing? This will deactivate it.')) {
                    e.preventDefault();
                }
            });

            form.addEventListener('submit', function (e) {
                const action = (e.submitter && e.submitter.value) || 'update';
                if (action === 'remove') return;

                errBox.textContent = '';
                const low = parseFloat(document.getElementById('lowInput').value);
                const middle = parseFloat(document.getElementById('middleInput').value);
                const high = parseFloat(document.getElementById('highInput').value);

                if (isNaN(low) || isNaN(middle) || isNaN(high)) {
                    e.preventDefault(); errBox.textContent = 'All three prices are required.'; return;
                }
                if (low <= 0 || middle <= 0 || high <= 0) {
                    e.preventDefault(); errBox.textContent = 'Prices must be greater than zero.'; return;
                }
                if (low > 10 || middle > 10 || high > 10) {
                    e.preventDefault(); errBox.textContent = 'Price per SMS looks too high — must be ≤ 10.'; return;
                }
                if (!(low >= middle && middle >= high)) {
                    e.preventDefault();
                    errBox.textContent = 'Tier order invalid: Low ≥ Medium ≥ High (bulk volume gets a cheaper rate).';
                    return;
                }
            });
        })();
    </script>
}